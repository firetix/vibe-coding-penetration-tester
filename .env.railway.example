# VibePenTester Railway environment baseline (M1)
# Copy/paste into Railway API + Worker services and replace placeholder values.

# ----------------------------------------------------------------------------
# Core runtime
# ----------------------------------------------------------------------------
VPT_ENV=production
VPT_HOSTED_MODE=1
VPT_TRUST_PROXY_HEADERS=1
VPT_ENABLE_MOCK_CHECKOUT=0
VPT_ALLOW_UNVERIFIED_WEBHOOKS=0

PORT=8080
WEB_CONCURRENCY=2
WEB_THREADS=4
WEB_TIMEOUT=180

# ----------------------------------------------------------------------------
# LLM providers (set at least one)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ----------------------------------------------------------------------------
# Billing / Stripe
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_CREDIT_PACK=

# ----------------------------------------------------------------------------
# Data stores
# Postgres powers both API persistence and worker queue claiming.
# ----------------------------------------------------------------------------
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Optional worker tuning
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_STEP_INTERVAL_SECONDS=1
WORKER_SIMULATED_STEPS=4
WORKER_RECONNECT_DELAY_SECONDS=5
WORKER_LOG_LEVEL=INFO
WORKER_RUN_ONCE=0

# ----------------------------------------------------------------------------
# Current code compatibility (SQLite billing/session/report artifacts)
# Mount a Railway volume at /data for durability across deploys.
# ----------------------------------------------------------------------------
VPT_BILLING_DB_PATH=/data/vpt.db
VPT_SESSION_FILE=/data/sessions.json
VPT_UPLOAD_FOLDER=/data/reports

# ----------------------------------------------------------------------------
# Supabase/Auth (for Next.js frontend + backend auth middleware)
# ----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
